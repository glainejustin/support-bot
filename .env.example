# ═══════════════════════════════════════════════════════════════════════════
#  🤖 SUPPORT BOT — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
#
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#
#  Then run the bot:
#    streamlit run bot.py
#
#  ⚠️  DO NOT commit .env to git! It's in .gitignore for your safety.
#      This .env.example file is safe to commit — it contains no real secrets.
#
#  On Streamlit Cloud / Render / Railway:
#    Use their built-in "Secrets" / "Environment Variables" UI instead.
#    See the "Deployment" section at the bottom of this file.
# ═══════════════════════════════════════════════════════════════════════════


# ═══════════════════════════════════════════════════════════════════════════
#  🔐 ADMIN PANEL PASSWORD
# ═══════════════════════════════════════════════════════════════════════════
#
#  The password to access the admin dashboard in the sidebar.
#  ⚠️  CHANGE THIS from "admin123" before deploying!
#      Use a password manager to generate a strong password.
#
#  The bot checks this env var first. If not set, it falls back to
#  the default in business_config.py.
#
#  Example: ADMIN_PASSWORD="K9#mP2$xL7@nR4!q"
#
ADMIN_PASSWORD="admin123"


# ═══════════════════════════════════════════════════════════════════════════
#  📧 RESEND API KEY (for automated follow-up emails)
# ═══════════════════════════════════════════════════════════════════════════
#
#  Required for the bot to send follow-up emails to captured leads.
#
#  1. Go to https://resend.com and sign up (free — 3,000 emails/month)
#  2. Go to Dashboard → API Keys → Create Key
#  3. Copy the key (starts with "re_")
#  4. Paste it below
#
#  Without this, the bot will still work — it just won't send emails.
#
#  Note: On Streamlit Cloud, this goes in Settings → Secrets as:
#    [resend]
#    api_key = "re_..."
#
RESEND_API_KEY=""


# ═══════════════════════════════════════════════════════════════════════════
#  📌 OPTIONAL: Custom Email "From" Address
# ═══════════════════════════════════════════════════════════════════════════
#
#  The email address that follow-up emails appear to come from.
#  On Resend's free tier, you can use "onboarding@resend.dev"
#  without any domain verification.
#
#  For your own domain, verify it in the Resend dashboard first.
#  Defaults to SUPPORT_EMAIL from business_config.py if not set.
#
#  Example: EMAIL_FROM="support@mybusiness.com"
#
# EMAIL_FROM="onboarding@resend.dev"


# ═══════════════════════════════════════════════════════════════════════════
#  STREAMLIT CLOUD — Alternative Setup (no .env file needed)
# ═══════════════════════════════════════════════════════════════════════════
#
#  On Streamlit Cloud, paste this into Settings → Secrets instead:
#
#  ┌─────────────────────────────────────────────────────────────┐
#  │  # ─── Admin Password ──────────────────────────────────    │
#  │  ADMIN_PASSWORD = "your-strong-password"                     │
#  │                                                              │
#  │  # ─── Resend (follow-up emails) ───────────────────────     │
#  │  [resend]                                                    │
#  │  api_key = "re_..."                                         │
#  └─────────────────────────────────────────────────────────────┘
#
#
#  ON RENDER / RAILWAY / FLY.IO:
#  Set these in their dashboard under Environment Variables:
#
#    ADMIN_PASSWORD  →  your-strong-password
#    RESEND_API_KEY  →  re_...
#
#  Then also set EMAIL_FROM in business_config.py or as an env var.
# ═══════════════════════════════════════════════════════════════════════════
